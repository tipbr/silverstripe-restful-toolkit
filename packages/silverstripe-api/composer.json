{
  "name": "app/silverstripe-api",
  "description": "Silverstripe 6 API scaffolding helpers with JWT authentication",
  "type": "silverstripe-vendormodule",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "silverstripe/framework": "^6",
    "silverstripe/security": "^6",
    "firebase/php-jwt": "^6.10"
  },
  "autoload": {
    "psr-4": {
      "App\\Api\\": "src/"
    }
  },
  "extra": {
    "expose": [
      "_config"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
